# ===================================================
# V ONE B — Variables de Entorno
# Copiar a .env y completar con valores reales
# ===================================================

# --- General ---
NODE_ENV=development
PORT=3000

# --- Base de Datos (PostgreSQL) ---
DATABASE_URL=postgresql://voneb:voneb_dev@localhost:5432/voneb_db?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- JWT Authentication ---
JWT_SECRET=change-me-to-a-secure-random-string-min-32-chars
JWT_REFRESH_SECRET=change-me-to-another-secure-random-string-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- WhatsApp ---
# Proveedor: "cloud-api" (produccion) o "baileys" (desarrollo)
WHATSAPP_PROVIDER=baileys
# WhatsApp Cloud API (solo para produccion)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=voneb-webhook-verify-token
# Numero de WhatsApp Business de V ONE B
WHATSAPP_BUSINESS_PHONE=+50600000000

# --- Pipeline CRM ---
PIPELINE_CRM_API_KEY=
PIPELINE_CRM_BASE_URL=https://api.pipelinecrm.com/api/v3

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=V ONE B <noreply@v-one-b.com>

# --- Notificaciones al Colaborador ---
# Numero de WhatsApp del colaborador que recibe alertas
COLLABORATOR_WHATSAPP=+50600000000
# Email del colaborador para reportes diarios
COLLABORATOR_EMAIL=admin@v-one-b.com

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# --- Logging ---
LOG_LEVEL=debug

# --- Shopify (futuro) ---
SHOPIFY_STORE_URL=
SHOPIFY_ACCESS_TOKEN=

# --- Timezone ---
TZ=America/Costa_Rica
